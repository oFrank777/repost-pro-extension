{
  "extends": "plasmo/templates/tsconfig.base",
  "compilerOptions": {
    "target": "es2022",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "types": ["chrome", "node"],
    "paths": {
      "~*": [
        "./*"
      ]
    },
    "baseUrl": "."
  },
  "exclude": [
    "node_modules",
    "**/*.test.tsx",
    "**/*.test.ts"
  ],
  "include": [
    ".plasmo/index.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ]
}
